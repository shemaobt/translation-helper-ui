# Backend target for the dockerized frontend stack (`docker compose up`).
# Set to "local" to proxy /api to http://host.docker.internal:8000 (no GCP auth needed).
# Set to "remote" to fetch BACKEND_URL from GCP Secret Manager
#   (requires `gcloud auth application-default login` + access to shemaobt-secrets).
BACKEND_TARGET=local

# Optional override for the GCP project that holds the secret.
# SECRETS_PROJECT_ID=shemaobt-secrets

# Local Vite dev (npm run dev) doesn't need any env vars — the dev server
# proxies /api to http://localhost:8000 automatically (see vite.config.ts).
